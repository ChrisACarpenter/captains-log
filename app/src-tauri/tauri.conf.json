{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Captain's Log",
  "version": "0.1.0",
  "identifier": "com.prodigygame.captainslog",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Captain's Log",
        "url": "/",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500
      },
      {
        "label": "capture",
        "title": "Captain's Log — Quick Capture",
        "url": "/capture",
        "width": 460,
        "height": 460,
        "minWidth": 380,
        "minHeight": 360,
        "resizable": true,
        "decorations": true,
        "visible": false,
        "focus": true,
        "center": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": "-",
      "minimumSystemVersion": "11.0"
    }
  }
}
