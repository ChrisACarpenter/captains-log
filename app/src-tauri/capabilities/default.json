{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for all Captain's Log windows",
  "windows": ["main", "capture"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-hide",
    "dialog:allow-open",
    "dialog:allow-confirm",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "x-apple.systempreferences:*" },
        { "url": "mailto:*" }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$TEMP/captainslog/**" }
      ]
    }
  ]
}
