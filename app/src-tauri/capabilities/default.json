{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for all Captain's Log windows",
  "windows": ["main", "capture"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:window:allow-hide",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-confirm",
    "clipboard-manager:allow-write-text",
    "clipboard-manager:allow-write-html",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$DOCUMENT/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOWNLOAD/**" }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "x-apple.systempreferences:*" },
        { "url": "mailto:*" },
        { "url": "http://*" },
        { "url": "https://*" }
      ]
    },
    {
      "identifier": "opener:allow-open-path",
      "allow": [
        { "path": "$TEMP/captainslog/**" }
      ]
    }
  ]
}
